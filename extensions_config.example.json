{
  "mcpServers": {
    "filesystem": {
      "enabled": true,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/path/to/allowed/files"
      ],
      "env": {},
      "description": "Provides filesystem access within allowed directories"
    },
    "office-suite": {
      "enabled": true,
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "python",
        "backend/mcp-servers/office-mcp/src/office_mcp_server/main.py"
      ],
      "env": {
        "PYTHONPATH": "backend/mcp-servers/office-mcp/src",
        "OUTPUT_DIR": "output"
      },
      "description": "Office document generation: Word (docx), Excel (xlsx), PowerPoint (pptx), PDF. Requires: pip install fastmcp python-docx openpyxl python-pptx reportlab scipy scikit-learn pandas numpy"
    },
    "mermaid": {
      "enabled": true,
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "mcp-mermaid"
      ],
      "env": {},
      "description": "Generate Mermaid diagrams as SVG/PNG images (flowcharts, sequence diagrams, ER diagrams, etc.)"
    },
    "github": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "description": "GitHub MCP server for repository operations"
    },
    "postgres": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/mydb"
      ],
      "env": {},
      "description": "PostgreSQL database access"
    }
  },
  "skills": {}
}
